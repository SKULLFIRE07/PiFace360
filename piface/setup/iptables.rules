*filter
:INPUT DROP [0:0]
:FORWARD DROP [0:0]
:OUTPUT ACCEPT [0:0]

# Allow loopback
-A INPUT -i lo -j ACCEPT

# Allow established and related connections
-A INPUT -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT

# Allow DHCP (UDP 67-68) on wlan0
-A INPUT -i wlan0 -p udp --dport 67:68 -j ACCEPT

# Allow DNS (TCP+UDP 53) on wlan0
-A INPUT -i wlan0 -p udp --dport 53 -j ACCEPT
-A INPUT -i wlan0 -p tcp --dport 53 -j ACCEPT

# Allow HTTP (80) on wlan0
-A INPUT -i wlan0 -p tcp --dport 80 -j ACCEPT

# Allow HTTPS (443) on wlan0
-A INPUT -i wlan0 -p tcp --dport 443 -j ACCEPT

COMMIT
